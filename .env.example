# Backend (Railway) environment variables.
# Anthropic API key for the /research endpoint. Without it, /research degrades
# gracefully; every other endpoint works.
ANTHROPIC_API_KEY=

# Comma-separated production browser origin(s) allowed by CORS, e.g. the Vercel
# domain: https://vitamin-advisor.vercel.app  (localhost dev origins are always
# allowed). Leave blank for local-only dev.
FRONTEND_ORIGIN=
